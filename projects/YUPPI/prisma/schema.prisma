// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id              Int                     @id @default(autoincrement())
  name            String
  nameEn          String?
  address         String?
  addressEn       String?
  district        String?
  districtEn      String?
  city            String?
  cityEn          String?
  country         String?
  countryEn       String?
  zipCode         String?
  taxOffice       String?
  taxOfficeEn     String?
  taxNo           String?
  registrationNo  String?
  phone           String?
  isSeller        Boolean                 @default(false)
  isBuyer         Boolean                 @default(false)
  isLogistics     Boolean                 @default(false)
  isCustoms       Boolean                 @default(false)
  isBrand         Boolean                 @default(false)
  isShipTo        Boolean                 @default(false)
  isInsurance     Boolean                 @default(false)
  
  repsJson        String                  @default("[]")

  sellerOrders    Order[]                 @relation("SellerContracts")
  buyerOrders     Order[]                 @relation("BuyerContracts")
  shipToOrders    Order[]                 @relation("ShipToContracts")
  brandOrders     Order[]                 @relation("BrandContracts")
  bankInfos       BankInfo[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model BankInfo {
  id        Int      @id @default(autoincrement())
  companyId Int
  currency  String // EUR, USD, GBP, TRY
  bankName  String
  branch    String?
  accountNo String?
  iban      String?
  swift     String?
  isDefault Boolean  @default(false)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Deprecated: left here to preserve existing logic if needed in older code, but unused now
model Representative {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           Int      @id @default(autoincrement())
  contractNo   String   @unique
  contractDate DateTime
  buyerPoNo    String?

  // Relationships
  sellerId    Int
  buyerId     Int
  shipToId    Int?
  brandId     Int?
  
  sellerRep   String?
  buyerRep    String?

  seller    Company                @relation("SellerContracts", fields: [sellerId], references: [id])
  buyer     Company                @relation("BuyerContracts", fields: [buyerId], references: [id])
  shipTo    Company?               @relation("ShipToContracts", fields: [shipToId], references: [id])
  brand     Company?               @relation("BrandContracts", fields: [brandId], references: [id])

  // Terms
  deliveryTerms       String?
  deliveryDestination String?
  paymentTerms        String?
  transporter         String?
  currency            String  @default("USD")
  unit                String  @default("MT") // MT, YD, KG, ADET
  language            String  @default("TR")

  // Tolerans
  tolerance String?

  // Specific Requests
  specialDocsRequest    Boolean @default(false)
  specialDocsDetail     String?
  specialLoadingRequest Boolean @default(false)
  specialLoadingDetail  String?

  // Extensions
  items           OrderItem[]
  productionOrder ProductionOrder?
  invoice         Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  orderId        Int
  buyerModelName String?
  qualityName    String?
  qualityCode    String?
  colorCode      String?
  composition    String?
  weight         String?
  width          String?
  quantity       Float
  unitPrice      Float
  totalAmount    Float
  deliveryDate   String?

  // Specific Item Requests
  bsRequest   Boolean @default(false)
  ldRequest   String? @default("WAIT") // YES, WAIT, NO
  ppsRequest  Boolean @default(false)
  topsRequest Boolean @default(false)
  srlRequest  Boolean @default(false)
  srlDetail   String?
  fdRequest   Boolean @default(false)
  pshpRequest Boolean @default(false)
  susRequest  Boolean @default(false)
  ltRequest   Boolean @default(false)
  ltDetail    String?

  // Production Tracking per Item
  bdd            DateTime? // B/S-DD (Bulk Sample Delivery Date)
  bq             Float? // B/S-Q (Bulk Sample Quantity)
  bsSentDate     DateTime? // B/S-SD (Bulk Sent Date)
  bsApprovalDate DateTime? // B/S-AD (Bulk Approval Date)
  exmd           DateTime?

  // Marketing Checklist
  etd            DateTime?
  fds            String?   @default("WAIT") // YES, WAIT, NO
  cs             String?   @default("WAIT") // YES, WAIT, NO
  csSentDate     DateTime?
  csApprovalDate DateTime?
  ldSentDate     DateTime?
  ldApprovalDate DateTime?

  // Further Approvals
  mpa   Boolean   @default(false)
  dpa   Boolean   @default(false)
  rs    String?   @default("WAIT") // YES, WAIT, NO
  rsMs  DateTime?
  bsMs  DateTime?
  bltRd DateTime?
  bltMs DateTime?
  bltMa DateTime?
  ltAd  DateTime?
  bsad  DateTime?

  // Post-Production fields
  pl         Boolean @default(false)
  fabricType String?
  apQuantity Float?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id                     Int       @id @default(autoincrement())
  orderId                Int       @unique
  exMillDate             DateTime?
  bulkDate               DateTime?
  packingInstructions    String?
  fabricDirection        String?
  partialShipmentAllowed Boolean   @default(false)

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id          Int       @id @default(autoincrement())
  orderId     Int       @unique
  invoiceNo   String?
  invoiceDate DateTime?
  grossKg     Float?
  netKg       Float?
  rollCount   Int?
  sackCount   Int?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
